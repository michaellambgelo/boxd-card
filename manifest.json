{
  "manifest_version": 3,
  "name": "Boxd Card",
  "version": "0.2.3",
  "description": "Generate a shareable image card from your Letterboxd profile.",
  "homepage_url": "https://github.com/michaellambgelo/boxd-card",
  "permissions": [
    "clipboardWrite",
    "activeTab",
    "declarativeContent"
  ],
  "host_permissions": [
    "https://letterboxd.com/*",
    "https://a.ltrbxd.com/*",
    "https://s.ltrbxd.com/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://letterboxd.com/*/",
        "https://letterboxd.com/*/diary/",
        "https://letterboxd.com/*/films/diary/",
        "https://letterboxd.com/*/list/*/"
      ],
      "js": [
        "src/content/index.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
